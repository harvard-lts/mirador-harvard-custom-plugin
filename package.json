{
  "name": "@harvard-lts/mirador-harvard-custom-plugin",
  "license": "Apache-2.0",
  "repository": "https://github.com/harvard-lts/mirador-harvard-custom-plugin.git",
  "keywords": [
    "react-component"
  ],
  "version": "2.0.0-beta.0",
  "description": "Mirador 4 plugin that adds Harvard branding (shield) and Copyright & Terms of Use label rewriting to the AttributionPanel",
  "module": "dist/es/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf ./dist && rm -rf ./demo/dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build",
    "build": "run-p build:es",
    "build:es": "rollup -c",
    "serve": "vite",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "peerDependencies": {
    "mirador": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@mui/material": "^7.0.0",
    "@mui/system": "^7.0.0",
    "@emotion/react": "^11.10.6",
    "@emotion/styled": "^11.10.6"
  },
  "devDependencies": {
    "@babel/cli": "^7.26.4",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.21.4",
    "@babel/preset-react": "^7.18.6",
    "@emotion/react": "^11.10.6",
    "@emotion/styled": "^11.10.6",
    "@mui/material": "^7.0.0",
    "@mui/system": "^7.0.0",
    "@rollup/plugin-babel": "^6.0.3",
    "@rollup/plugin-image": "^3.0.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "jsdom": "^23.0.0",
    "mirador": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rollup": "^3.29.5",
    "url": "^0.11.4",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
